<%
  # FAQ data: add/remove/reorder items here
  faqs = [
    {
      question: "What is YSWS?",
      answer: "This ysws is where you submit something related to banking/money/finances and we ship you a simplefin subscription or something financially related to helping your project!"
    },
    {
      question: "How do I get started?",
      answer: "You cant as of right now! this isnt a real ysws yet, just a draft."
    },
    {
      question: "Is this actually responsible financial advice?",
      answer: "this is not financial advice."
    },
    {
      question: "I need help!",
      answer: "Contact for help in the slack in #financial (https://hackclub.enterprise.slack.com/archives/C0AMG9HNGQG) or @neon on the slack. If you cannot access the slack for some reason email neon@hackclub.com"
    },
    {
      question: "How much does it cost?",
      answer: "For you, not a dime! You will have to work more then 3hr (15$!!) before submitting your project tho and after that its 4.5$/hr more. "
    }
  ]
%>

<section class="max-w-4xl mx-auto px-6 py-20">
  <h2 class="text-4xl font-bold text-white mb-12 text-center" style="font-family: 'Open Sans', sans-serif;">
    Frequently Asked Questions
  </h2>

  <div class="space-y-6">
    <% faqs.each do |faq| %>
      <details class="group bg-white/10 backdrop-blur-sm rounded-xl p-6 cursor-pointer">
        <summary class="text-xl font-semibold text-white list-none flex justify-between items-center">
          <%= faq[:question] %>
          <span class="transition-transform duration-300 group-open:rotate-45 text-2xl">+</span>
        </summary>
        <p class="mt-4 text-white/80 leading-relaxed">
          <%= faq[:answer] %>
        </p>
      </details>
    <% end %>
  </div>
</section>
