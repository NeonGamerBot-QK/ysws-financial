<%
  # FAQ data: add/remove/reorder items here
  faqs = [
    {
      question: "What is YSWS?",
      answer: "YSWS (You Ship, We Ship) is a Hack Club program — you build and ship a project related to banking, money, or personal finances, and we'll ship you a SimpleFIN subscription or something financially useful to help your project!"
    },
    {
      question: "How do I get started?",
      answer: "This YSWS hasn't officially launched yet! RSVP with your email above and we'll let you know as soon as it's live."
    },
    {
      question: "What counts as a valid project?",
      answer: "Anything related to banking, money, or personal finances — budgeting tools, expense trackers, payment integrations, financial dashboards, you name it. Get creative!"
    },
    {
      question: "How much does it cost?",
      answer: "Nothing! It's completely free. You just need to log at least 3 hours of work ($15 minimum value) before submitting your project. After that, additional hours are valued at $4.50/hr."
    },
    {
      question: "Is this actually financial advice?",
      answer: "Nope. This is not financial advice."
    },
    {
      question: "I need help!",
      answer: "Reach out in #financial on the Hack Club Slack (https://hackclub.enterprise.slack.com/archives/C0AMG9HNGQG) or DM @neon. If you can't access Slack, email neon@hackclub.com."
    }
  ]
%>

<section class="max-w-4xl mx-auto px-6 py-20">
  <h2 class="text-4xl font-bold text-white mb-12 text-center" style="font-family: 'Open Sans', sans-serif;">
    Frequently Asked Questions
  </h2>

  <div class="space-y-6">
    <% faqs.each do |faq| %>
      <details class="group bg-white/10 backdrop-blur-sm rounded-xl p-6 cursor-pointer">
        <summary class="text-xl font-semibold text-white list-none flex justify-between items-center">
          <%= faq[:question] %>
          <span class="transition-transform duration-300 group-open:rotate-45 text-2xl">+</span>
        </summary>
        <p class="mt-4 text-white/80 leading-relaxed">
          <%= faq[:answer] %>
        </p>
      </details>
    <% end %>
  </div>
</section>
