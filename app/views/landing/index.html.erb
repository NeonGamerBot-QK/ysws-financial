<!-- Hero: title + RSVP, fades out on scroll -->
<div id="hero-group" class="fixed z-50 will-change-transform m-20 lg:m-0 px-6 lg:px-0">
  <h1 id="hero-title" class="text-3xl sm:text-5xl lg:text-7xl font-bold text-white pointer-events-none" style="font-family: 'Open Sans', sans-serif;">
    Financial <span class="text-gray-500 text-sm">(not responsibility tho)</span>
  </h1>
  <p class="text-white/80">You ship an app related to banking, money, or finances — we ship you a SimpleFIN subscription!</p>
  <%= render "landing/rsvp" %>
</div>

<!-- Hero spacer: one screen tall -->
<div class="min-h-screen"></div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const heroGroup = document.getElementById("hero-group");
    const title = document.getElementById("hero-title");

    /** Breakpoint: disable scroll animation at or below 1024px */
    const MOBILE_BREAKPOINT = 1024;

    /** Scroll distance (in px) over which the animation completes */
    const SCROLL_THRESHOLD = 400;

    /**
     * Apply easeOutCubic for smooth deceleration.
     * @param {number} t - Linear progress from 0 to 1
     * @returns {number} Eased progress
     */
    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function isMobile() {
      return window.innerWidth <= MOBILE_BREAKPOINT;
    }

    function getCenterPosition() {
      return {
        x: (window.innerWidth - title.offsetWidth) / 2,
        y: (window.innerHeight - title.offsetHeight) / 2,
      };
    }

    // End position (top-left corner with padding)
    const END_X = 24;
    const END_Y = 24;
    const END_SCALE = 0.4;

    function resetToCenter() {
      heroGroup.style.position = "relative";
      heroGroup.style.left = "";
      heroGroup.style.top = "";
      heroGroup.style.transform = "";
    }

    function setupFixed() {
      heroGroup.style.position = "";
      const center = getCenterPosition();
      heroGroup.style.left = `${center.x}px`;
      heroGroup.style.top = `${center.y}px`;
    }

    let center = getCenterPosition();

    if (isMobile()) {
      resetToCenter();
    } else {
      heroGroup.style.left = `${center.x}px`;
      heroGroup.style.top = `${center.y}px`;
    }

    window.addEventListener("resize", () => {
      center = getCenterPosition();
      if (isMobile()) {
        resetToCenter();
      } else {
        setupFixed();
      }
    });

    const rsvpBlock = heroGroup.querySelector(".rsvp-block");

    window.addEventListener("scroll", () => {
      if (isMobile()) return;

      const linearProgress = Math.min(window.scrollY / SCROLL_THRESHOLD, 1);
      const progress = easeOutCubic(linearProgress);

      // Title moves to top-left corner
      const scale = 1 - (progress * (1 - END_SCALE));
      const currentX = center.x + (END_X - center.x) * progress;
      const currentY = center.y + (END_Y - center.y) * progress;

      heroGroup.style.left = `${currentX}px`;
      heroGroup.style.top = `${currentY}px`;
      heroGroup.style.transform = `scale(${scale})`;
      heroGroup.style.transformOrigin = "top left";

      // RSVP just fades out
      rsvpBlock.style.opacity = 1 - progress;
      rsvpBlock.style.pointerEvents = progress >= 1 ? "none" : "";
    });
  });
</script>

<%= render "landing/faq" %>

<div class="max-w-4xl mx-auto px-6 py-12">
  <%= render "landing/rsvp" %>
</div>

<%= render "landing/carousel" if ENV["SHOW_OTHERS_COL"] %>
