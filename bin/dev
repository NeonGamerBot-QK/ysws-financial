#!/usr/bin/env ruby

# Default to port 3000 if not specified
ENV["PORT"] ||= "3000"

# Check if foreman is installed, install if not
fork_exec = ->(cmd) { exec(*cmd.split(" ")) }

if system("which foreman > /dev/null 2>&1")
  fork_exec.call("foreman start -f Procfile.dev")
else
  puts "Installing foreman..."
  system("gem install foreman") || abort("Failed to install foreman")
  fork_exec.call("foreman start -f Procfile.dev")
end
